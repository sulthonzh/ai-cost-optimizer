{
  "name": "ai-cost-optimizer",
  "version": "1.1.0",
  "description": "Zero-dependency CLI tool for optimizing AI operational costs and improving cost efficiency",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-cost-optimizer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cost",
    "optimization",
    "llm",
    "token",
    "tracking",
    "analytics",
    "cli"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^10.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
