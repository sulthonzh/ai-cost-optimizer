{
  "name": "ai-cost-optimizer",
  "version": "1.1.0",
  "description": "Zero-dependency CLI tool for optimizing AI operational costs and improving cost efficiency",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-cost-optimizer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cost",
    "optimization",
    "llm",
    "token",
    "tracking",
    "analytics",
    "cli"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.0.0",
    "tsup": "^8.0.0",
    "typescript": "^7.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sulthonzh/ai-cost-optimizer.git"
  },
  "homepage": "https://github.com/sulthonzh/ai-cost-optimizer#readme",
  "bugs": {
    "url": "https://github.com/sulthonzh/ai-cost-optimizer/issues"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
